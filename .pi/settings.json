{
  "provider": "openrouter",
  "model": "z-ai/glm-5.1",
  "defaultThinkingLevel": "high",
  "thinkingBudgets": {
    "off": 0,
    "minimal": 5000,
    "low": 8000,
    "medium": 15000,
    "high": 25000,
    "xhigh": 40000
  },
  "models": [
    "auto",
    "google/gemini-3.1-pro-preview",
    "google/gemini-3-flash-preview",
    "z-ai/glm-5.1",
    "minimax/minimax-m2.7",
    "google/gemma-4-31b-it"
  ],
  "transport": "auto",
  "steeringMode": "one-at-a-time",
  "followUpMode": "one-at-a-time",
  "compaction": {
    "enabled": false
  },
  "retries": {
    "enabled": true,
    "maxRetries": 4,
    "initialDelayMs": 1000,
    "maxDelayMs": 60000,
    "backoffMultiplier": 2
  },
  "editor": {
    "padding": 2,
    "lineNumbers": true,
    "wordWrap": true,
    "fontSize": 13
  },
  "quietStartup": false,
  "skipVersionCheck": false,
  "theme": "dark",
  "packages": [
    "npm:pi-subagents"
  ]
}