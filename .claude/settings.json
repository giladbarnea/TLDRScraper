{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "10000000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "10000000",
    "BASH_DEFAULT_TIMEOUT_MS": "60000",
    "BASH_MAX_OUTPUT_LENGTH": "100000",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./setup.sh --quiet"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-gh-command.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "serena@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "architecture-doc@local-plugins": false
  },
  "sandbox": {
    "enabled": false,
    "network": {
      "allowLocalBinding": true
    },
    "excludedCommands": []
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
